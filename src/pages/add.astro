---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---
<DefaultLayout title="Home" description="desc">
    <div id="webCryptoAPI-FailAlert" class="alert alert-danger" role="alert" style="display: none;">
        WebCrypto API not available - Make sure to use HTTPS and a modern browser.
    </div>
    <div id="public-key-fail" class="alert alert-danger" role="alert" style="display: none;">
        Public key corrupted!
    </div>

    <div id="main-div">
        <h2>Add a public key?</h2>
        <p>
            UserID: <span id="userid-span"></span><br>
            Fingerprint: <span id="fingerprint-span"></span>
        </p>
        <button class="btn btn-primary">Importa</button>
        <button class="btn btn-danger">Non importare</button>
    </div>

    <script>
        import { hexToKey } from "@/utils/helpers.js";

        const queryString = window.location.search;
        const urlParams = new URLSearchParams(queryString);
        // const publicKey = urlParams.get("k");
        let publicKey = ""

        function corruptedKey() {
            document.getElementById("public-key-fail").style.display = "block";
            document.getElementById("main-div").innerHTML = "back to home";
        }

        if (!publicKey) corruptedKey();

        try {
            hexToKey(publicKey).then(key => {
                if (!key) corruptedKey()
                else {const userIDs = key.getUserIDs();
                    let userID;
                    if (userIDs && userIDs.length > 0) {
                        // Return the primary or first user ID
                        userID = userIDs[0];
                    } else {
                        userID = "No userID";
                    }
                    const fingerprint = key.getFingerprint();

                    document.getElementById("userid-span").textContent = userID;
                    document.getElementById("fingerprint-span").textContent = fingerprint.replace(/(.{4})(?!$)/g, '$1 ').toUpperCase();
                }
            });
        } catch (e) {
            corruptedKey()
        }

    </script>
</DefaultLayout>