---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---
<DefaultLayout title="Home" description="desc">
    <form id="key-generation-form" class="my-5 w-50 mx-auto">
        <h2>Generate key pair</h2>

        <fieldset>
            <legend>Key type</legend>
            <div class="mb-3 form-check">
                <input class="form-check-input" type="radio" name="key-type-radio" id="curve-radio" value="curve" checked>
                <label class="form-check-label" for="curve-radio">Curve 255 bit</label>
            </div>
            <div class="mb-3 form-check">
                <input class="form-check-input" type="radio" name="key-type-radio" id="rsa-radio" value="rsa">
                <label class="form-check-label" for="rsa-radio">RSA 2048 bit</label>
            </div>
        </fieldset>

        <div class="mb-3">
            <label for="full-name" class="form-label">Full name</label>
            <input type="text" class="form-control" id="full-name" name="full-name">
        </div>
        <div class="mb-3">
            <label for="email" class="form-label">Email address</label>
            <input type="email" class="form-control" id="email" name="email" required>
        </div>

        <div class="mb-3">
            <label for="passphrase" class="form-label">Passphrase</label>
            <input type="password" class="form-control" id="passphrase" aria-describedby="passphraseHelp" name="passphrase">
            <div id="passphraseHelp" class="form-text">We'll never share your passphrase with anyone.</div>
        </div>

        <fieldset>
            <legend>Expiration date</legend>
            <div id="expiration-date-form">
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="expiration-date" id="one-year-radio" value="1" checked>
                    <label class="form-check-label" for="one-year-radio">1 Year</label>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="expiration-date" id="two-year-radio" value="2">
                    <label class="form-check-label" for="two-year-radio">2 Years</label>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="expiration-date" id="three-year-radio" value="3">
                    <label class="form-check-label" for="three-year-radio">3 Years</label>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="expiration-date" id="custom-year-radio" value="custom">
                    <label class="form-check-label" for="custom-year-radio">Custom</label>
                    <div class="mt-2">
                        <label for="datePicker" class="form-label">Select a Date</label>
                        <input type="date" class="form-control" id="datePicker" name="custom-date" required disabled>
                    </div>
                </div>
            </div>
        </fieldset>

        <div class="w-100 text-center">
            <button type="submit" class="btn btn-primary btn-lg">Generate</button>
        </div>
    </form>

    <div id="show-keys-div" class="mb-5 w-50 mx-auto" style="display: none;">
        <h3>Public key</h3>
        <textarea id="public-key-textarea" class="w-75 mb-2" readonly></textarea>
        <button id="download-button-public-key" class="btn btn-primary btn mb-4">Download public key</button>
        <h3>Private key</h3>
        <textarea id="private-key-textarea" class="w-75 mb-2" readonly></textarea>
        <button id="download-button-private-key" class="btn btn-primary btn mb-4">Download private key</button>
        <h3>Revocation certificate</h3>
        <textarea id="revocation-certificate-textarea" class="w-75 mb-2" readonly></textarea>
        <button id="download-button-revocation-certificate" class="btn btn-primary btn">Download revocation certificate</button>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-success text-light">
                <strong class="me-auto">Key generated successfully</strong>
                <small>Now</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                The key is saved securly. Check it out in the "Keys" tab.
            </div>
        </div>
    </div>

    <script>
        const expirationDateForm = document.getElementById("expiration-date-form");
        const datePicker = document.getElementById("datePicker");

        expirationDateForm?.addEventListener("change", (event) => {
            const selectedValue = event.target.value;
            
            if (selectedValue === "1" || selectedValue === "2" || selectedValue === "3") {
                datePicker.disabled = true;
            } else {
                datePicker.disabled = false;
            }
        });
    </script>
</DefaultLayout>