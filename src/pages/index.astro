---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---
<DefaultLayout title="Home" description="desc">
    <form id="key-generation-form">
        <div id="webCryptoAPI-FailAlert" class="alert alert-danger" role="alert" style="display: none;">
            WebCrypto API not available - Make sure to use HTTPS and a modern browser.
        </div>
        <fieldset id="fieldset">
            <h2>Generate key pair</h2>
            <fieldset>
                <legend>Key type</legend>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="key-type-radio" id="curve255-radio" value="curve255" checked>
                    <label class="form-check-label" for="curve255-radio">Curve 255 bit (v4)</label>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="key-type-radio" id="curve255-exp-radio" value="curve255-exp">
                    <label class="form-check-label" for="curve255-exp-radio">Curve 255 bit (v6 - experimental)</label>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="key-type-radio" id="rsa2048-radio" value="rsa2048">
                    <label class="form-check-label" for="rsa2048-radio">RSA 2048 bit</label>
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="radio" name="key-type-radio" id="rsa4096-radio" value="rsa4096">
                    <label class="form-check-label" for="rsa4096-radio">RSA 4096 bit</label>
                </div>
            </fieldset>

            <div class="mb-3">
                <label for="full-name" class="form-label">Full name</label>
                <input type="text" class="form-control" id="full-name" name="full-name">
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email address</label>
                <input type="email" class="form-control" id="email" name="email" required>
            </div>

            <div class="mb-3">
                <label for="passphrase" class="form-label">Passphrase</label>
                <input type="password" class="form-control" id="passphrase" aria-describedby="passphraseHelp" name="passphrase">
                <div id="passphraseHelp" class="form-text">We'll never share your passphrase with anyone.</div>
            </div>

            <fieldset>
                <legend>Expiration date</legend>
                <div id="expiration-date-form">
                    <div class="mb-3 form-check">
                        <input class="form-check-input" type="radio" name="expiration-date" id="one-year-radio" value="1" checked>
                        <label class="form-check-label" for="one-year-radio">1 Year</label>
                    </div>
                    <div class="mb-3 form-check">
                        <input class="form-check-input" type="radio" name="expiration-date" id="two-year-radio" value="2">
                        <label class="form-check-label" for="two-year-radio">2 Years</label>
                    </div>
                    <div class="mb-3 form-check">
                        <input class="form-check-input" type="radio" name="expiration-date" id="three-year-radio" value="3">
                        <label class="form-check-label" for="three-year-radio">3 Years</label>
                    </div>
                    <div class="mb-3 form-check">
                        <input class="form-check-input" type="radio" name="expiration-date" id="custom-year-radio" value="custom">
                        <label class="form-check-label" for="custom-year-radio">Custom</label>
                        <div class="mt-2">
                            <label for="datePicker" class="form-label">Select a Date</label>
                            <input type="date" class="form-control" id="datePicker" name="custom-date" required disabled>
                        </div>
                    </div>
                </div>
            </fieldset>

            <div class="w-100 text-center">
                <button type="submit" class="btn btn-primary btn-lg">Generate</button>
            </div>
        </fieldset>
    </form>

    <div id="show-keys-div" class="mt-3" style="display: none;">
        <h3>Public key</h3>
        <textarea id="public-key-textarea" class="w-75 mb-2" readonly></textarea>
        <br><button id="download-button-public-key" class="btn btn-primary btn mb-4">Download public key</button>
        <h3>Private key</h3>
        <textarea id="private-key-textarea" class="w-75 mb-2" readonly></textarea>
        <br><button id="download-button-private-key" class="btn btn-primary btn mb-4">Download private key</button>
        <h3>Revocation certificate</h3>
        <textarea id="revocation-certificate-textarea" class="w-75 mb-2" readonly></textarea>
        <br><button id="download-button-revocation-certificate" class="btn btn-primary btn">Download revocation certificate</button>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-success text-light">
                <strong class="me-auto">Key generated successfully</strong>
                <small>Now</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                The key is saved securly. Check it out in the "Keys" tab.
            </div>
        </div>
        <div id="indexeddb-FailToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-danger text-light">
                <strong class="me-auto">IndexedDB fail</strong>
                <small>Now</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                The generated key was not saved in the database!
            </div>
        </div>
    </div>

    <script>
        import Toast from "bootstrap/js/dist/toast";
        import { saveKeys, downloadTextAsFile } from "@/utils/helpers.js";
        import { generateKey, readKey } from "openpgp";

        const datePicker = document.getElementById("datePicker");
        const form = document.getElementById("key-generation-form");
        const publicKeyTextarea = document.getElementById("public-key-textarea");
        const privateKeyTextarea = document.getElementById("private-key-textarea");
        const revocationCertificateTextarea = document.getElementById("revocation-certificate-textarea");
        const showKeysDiv = document.getElementById("show-keys-div");

        const ONE_YEAR = 60 * 60 * 24 * 365;

        async function generateKeys(options) {
            const { privateKey, publicKey, revocationCertificate } = await generateKey({
                type: options.type,
                rsaBits: options.rsaBits,
                curve: options.curve,
                userIDs: options.userIDs,
                passphrase: options.passphrase,
                keyExpirationTime: options.keyExpirationTime
            });

            const key = await readKey({ armoredKey: publicKey });
            const fingerprint = key.getFingerprint();

            showKeys(publicKey, privateKey, revocationCertificate);

            saveKeys(fingerprint, publicKey, privateKey, revocationCertificate);
        }

        function showKeys(publicKey: string, privateKey: string, revocationCertificate: string) {
            if (publicKeyTextarea) publicKeyTextarea.textContent = publicKey;
            if (privateKeyTextarea) privateKeyTextarea.textContent = privateKey;
            if (revocationCertificateTextarea) revocationCertificateTextarea.textContent = revocationCertificate;

            if (showKeysDiv) {
                showKeysDiv.style.display = "block";
                showKeysDiv.scrollIntoView();
            }
        }

        document.getElementById("expiration-date-form")?.addEventListener("change", (e) => {
            const selectedValue = e.target?.value;
            
            if (selectedValue === "1" || selectedValue === "2" || selectedValue === "3") {
                datePicker.disabled = true;
            } else {
                datePicker.disabled = false;
            }
        });

        form?.addEventListener("submit", (e) => {
            e.preventDefault();

            const formData = new FormData(form);

            const keyType = formData.get("key-type-radio");
            const name = formData.get("full-name");
            const email = formData.get("email");
            const passphrase = formData.get("passphrase");
            const expirationDate = formData.get("expiration-date");

            let keyExpirationTime;
            switch (expirationDate) {
                case "custom":
                    const dateObject = new Date(formData.get("custom-date"));
                    keyExpirationTime = (dateObject.getTime() / 1000) - Math.floor(Date.now() / 1000);
                    break;
                case "1":
                    keyExpirationTime = ONE_YEAR;
                    break;
                case "2":
                    keyExpirationTime = ONE_YEAR * 2;
                    break;
                case "3":
                    keyExpirationTime = ONE_YEAR * 3;
                    break;
                default:
                    alert("expirationDate not defined!");
                    return;
            }

            switch (keyType) {
                case "curve255":
                    generateKeys({
                        type: "ecc",
                        curve: "curve25519Legacy",
                        userIDs: [{ name, email }],
                        passphrase: passphrase,
                        keyExpirationTime: keyExpirationTime
                    });
                    break;
                case "curve255-exp":
                    generateKeys({
                        type: "curve25519",
                        userIDs: [{ name, email }],
                        passphrase: passphrase,
                        keyExpirationTime: keyExpirationTime
                    });
                    break;
                case "rsa2048":
                    generateKeys({
                        type: "rsa",
                        rsaBits: 2048,
                        userIDs: [{ name, email }],
                        passphrase: passphrase,
                        keyExpirationTime: keyExpirationTime
                    });
                    break;
                case "rsa4096":
                    generateKeys({
                        type: "rsa",
                        rsaBits: 4096,
                        userIDs: [{ name, email }],
                        passphrase: passphrase,
                        keyExpirationTime: keyExpirationTime
                    });
                    break;
                default:
                    alert("keyType not defined!");
                    return;
            }

            Toast.getOrCreateInstance(
                document.getElementById("successToast"),
                {
                    delay: 7000,
                    autohide: true
                }
            ).show();
        });

        document.getElementById("download-button-public-key")?.addEventListener("click", () => {
            downloadTextAsFile(publicKeyTextarea?.value, "public_key.asc");
        });
        document.getElementById("download-button-private-key")?.addEventListener("click", () => {
            downloadTextAsFile(privateKeyTextarea?.value, "private_key.asc");
        });
        document.getElementById("download-button-revocation-certificate")?.addEventListener("click", () => {
            downloadTextAsFile(revocationCertificateTextarea?.value, "revocation_certificate.asc");
        });
    </script>
</DefaultLayout>